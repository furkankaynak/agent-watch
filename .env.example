# Aktivite log dosyasinin yolu
# Varsayilan: proje kokundeki activity.log
# Ornek (Windows):
# ACTIVITY_LOG_PATH=C:\Users\kullanici\path\to\activity.log
# Ornek (Mac/Linux):
# ACTIVITY_LOG_PATH=/path/to/activity.log

# Arayuzde agent hatalarini gizler (failed status, error mesajlari)
# VITE_HIDE_ERRORS=true
